def build_intrinsic_table() -> Vec(IntrinRow) {
    Vec(IntrinRow) t = {}
    _b0(&!t)
    _b1(&!t)
    _b2(&!t)
    _b3(&!t)
    _b4(&!t)
    _b5(&!t)
    _b6(&!t)
    _b7(&!t)
    _b8(&!t)
    return t
}

// resolve an intrinsic name to its modelled mnemonic; "" if unknown.
def mnemonic_of(&Vec(IntrinRow) t, &Str name) -> Str {
    int n = t.len()
    for i in 0..n {
        &IntrinRow r = t.get_ref(i)
        if r.name.eq?(name) { return r.mnem.copy() }
    }
    return ""
}
