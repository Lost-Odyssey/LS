# Intel SDM PDF + local extraction (IP-sensitive document material, large; the GENERATED
# lib/sim/intel/{intrinsics,specdoc}.ls are committed, the source is not — re-run
# tools/extract_sdm_vol2.py to regenerate). Never commit the PDF or the extracted prose.
*.pdf
# Compute-class C-like pseudocode, GENERATED from the Intel Intrinsics Guide operation text
# (references/intrinsics/gen_pseudo.py). Derived from license-restricted source -> local-only,
# NOT imported by the committed gallery. Never commit.
/lib/sim/intel/pseudo.ls
build-lc/

# ls test transient driver files
*.lstest.ls

# local AI model-compiler demo (not part of the language/stdlib).
# Root-anchored: ignores the top-level demo dir only, NOT lib/model/ (the
# tracked .lsm toolchain library).
/model/
